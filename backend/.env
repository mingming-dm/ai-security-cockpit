# ============================================
# 智盾校园 AI 安全驾驶舱 - 后端配置
# ============================================

# 服务端口
PORT=3001

# JWT 密钥 (生产环境请更换为复杂随机字符串)
JWT_SECRET=campus-ai-security-jwt-secret-2024

# ============================================
# AI 提供商配置
# 可选值: openai | deepseek | openclaw | tianyi | demo
# demo 模式使用内置规则引擎，无需 API Key
# ============================================
AI_PROVIDER=demo

# OpenAI 配置
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# DeepSeek 配置
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 天翼云大模型配置
TIANYI_API_KEY=your-tianyi-key
TIANYI_BASE_URL=https://api-tianyiyun.com/v1
TIANYI_MODEL=tianyi-large

# OpenClaw 配置
OPENCLAW_API_KEY=your-openclaw-key
OPENCLAW_BASE_URL=https://api.openclaw.com/v1
OPENCLAW_MODEL=openclaw-chat
